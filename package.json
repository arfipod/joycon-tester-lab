{
  "name": "joycon-webhid-poc",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Local Joy-Con HID vibration tester.",
  "scripts": {
    "dev": "node scripts/local-app.mjs",
    "joycon:list": "node scripts/joycon-rumble.mjs list",
    "joycon:left": "node scripts/joycon-rumble.mjs pulse --side left --intensity high --duration 900 --repeats 2",
    "joycon:right": "node scripts/joycon-rumble.mjs pulse --side right --intensity high --duration 900 --repeats 2",
    "joycon:both": "node scripts/joycon-rumble.mjs pulse --side both --intensity high --duration 700 --repeats 1",
    "joycon:pulse": "node scripts/joycon-rumble.mjs pulse"
  },
  "engines": {
    "node": ">=20 <23",
    "npm": ">=10"
  },
  "packageManager": "npm@10.9.2",
  "keywords": [
    "hid",
    "joy-con",
    "nintendo-switch",
    "haptics"
  ],
  "license": "MIT",
  "devDependencies": {
    "node-hid": "^3.3.0"
  }
}
